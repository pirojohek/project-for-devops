#!/bin/bash

# === Параметры ===
USER={{ postgres_username }}
DB={{ postgres_db }}
HOST={{ postgres_host }}
PORT={{ postgres_port }}

BASE_DIR="$HOME/postgres_backup"
DUMP_DIR="$BASE_DIR/dumps"
LOG_DIR="$BASE_DIR/logs"

DATE=$(date +"%Y-%m-%d_%H-%M-%S")
FILENAME="${DB}_$DATE.dump"

REMOTE="yadisk:postgres_backups"
LOG_FILE="$LOG_DIR/backup.log"

# === Начало логирования ===
echo "==============================" | tee -a "$LOG_FILE"
echo "Запуск бэкапа: $(date)" | tee -a "$LOG_FILE"

# === Создание дампа ===
echo "Создаём бэкап базы $DB..." | tee -a "$LOG_FILE"

pg_dump \
-U "$USER" \
-h "$HOST" \
-p "$PORT" \
-F c \
-b \
-v \
-f "$DUMP_DIR/$FILENAME" \
"$DB" 2>&1 | tee -a "$LOG_FILE"

if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo "Ошибка создания бэкапа!" | tee -a "$LOG_FILE"
    exit 1
fi

# === Проверка целостности ===
echo "Проверка целостности..." | tee -a "$LOG_FILE"

pg_restore -l "$DUMP_DIR/$FILENAME" > /dev/null

if [ $? -ne 0 ]; then
    echo "Бэкап повреждён!" | tee -a "$LOG_FILE"
    exit 1
fi

# === Копирование в Яндекс.Диск ===
echo "Копирование на удалённый диск..." | tee -a "$LOG_FILE"

rclone copy "$DUMP_DIR/$FILENAME" "$REMOTE" 2>&1 | tee -a "$LOG_FILE"

if [ $? -ne 0 ]; then
    echo "Ошибка копирования в облако!" | tee -a "$LOG_FILE"
    exit 1
fi

# === Удаление старых бэкапов (оставляем последние 7) ===
echo "Удаление старых бэкапов..." | tee -a "$LOG_FILE"

ls -1tr "$DUMP_DIR"/*.dump 2>/dev/null | head -n -7 | xargs -r rm -f

# === Завершение ===
echo "Бэкап завершён: $FILENAME" | tee -a "$LOG_FILE"
echo "Время завершения: $(date)" | tee -a "$LOG_FILE"