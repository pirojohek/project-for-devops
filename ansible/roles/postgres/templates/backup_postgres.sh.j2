#!/bin/bash

# === Параметры ===
USER=my_user
DB=mydb
HOST=localhost
PORT=5432

BASE_DIR="$HOME/postgres_backup"
DUMP_DIR="$BASE_DIR/dumps"
LOG_DIR="$BASE_DIR/logs"

DATE=$(date +"%Y-%m-%d_%H-%M-%S")
FILENAME="${DB}_$DATE.dump"

REMOTE="yadisk:postgres_backups"
LOG_FILE="$LOG_DIR/backup.log"

# === Файл метрик для node-exporter ===
METRIC_FILE="/var/lib/node_exporter/textfile_collector/backup.prom"

write_metrics_success() {
cat <<EOF > "$METRIC_FILE"
# HELP backup_success Last backup success (1 = ok, 0 = fail)
# TYPE backup_success gauge
backup_success 1

# HELP backup_failure Last backup failure (1 = fail, 0 = ok)
# TYPE backup_failure gauge
backup_failure 0

# HELP backup_timestamp Unix timestamp of last backup
# TYPE backup_timestamp gauge
backup_timestamp $(date +%s)

# HELP backup_success_total Total successful backups
# TYPE backup_success_total counter
backup_success_total $(( $(grep -E "backup_success_total [0-9]+" "$METRIC_FILE" | awk '{print $2}' 2>/dev/null) + 1 ))

# HELP backup_failure_total Total failed backups
# TYPE backup_failure_total counter
backup_failure_total $(( $(grep -E "backup_failure_total [0-9]+" "$METRIC_FILE" | awk '{print $2}' 2>/dev/null) ))
EOF
}

write_metrics_failure() {
cat <<EOF > "$METRIC_FILE"
# HELP backup_success Last backup success (1 = ok, 0 = fail)
# TYPE backup_success gauge
backup_success 0

# HELP backup_failure Last backup failure (1 = fail, 0 = ok)
# TYPE backup_failure gauge
backup_failure 1

# HELP backup_timestamp Unix timestamp of last backup
# TYPE backup_timestamp gauge
backup_timestamp $(date +%s)

# HELP backup_success_total Total successful backups
# TYPE backup_success_total counter
backup_success_total $(( $(grep -E "backup_success_total [0-9]+" "$METRIC_FILE" | awk '{print $2}' 2>/dev/null) ))

# HELP backup_failure_total Total failed backups
# TYPE backup_failure_total counter
backup_failure_total $(( $(grep -E "backup_failure_total [0-9]+" "$METRIC_FILE" | awk '{print $2}' 2>/dev/null) + 1 ))
EOF
}

# === Начало логирования ===
echo "==============================" | tee -a "$LOG_FILE"
echo "Запуск бэкапа: $(date)" | tee -a "$LOG_FILE"

# === Создание дампа ===
echo "Создаём бэкап базы $DB..." | tee -a "$LOG_FILE"

pg_dump \
-U "$USER" \
-h "$HOST" \
-p "$PORT" \
-F c \
-b \
-v \
-f "$DUMP_DIR/$FILENAME" \
"$DB" 2>&1 | tee -a "$LOG_FILE"

if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo "Ошибка создания бэкапа!" | tee -a "$LOG_FILE"
    write_metrics_failure
    exit 1
fi

# === Проверка целостности ===
echo "Проверка целостности..." | tee -a "$LOG_FILE"

pg_restore -l "$DUMP_DIR/$FILENAME" > /dev/null

if [ $? -ne 0 ]; then
    echo "Бэкап повреждён!" | tee -a "$LOG_FILE"
    write_metrics_failure
    exit 1
fi

# === Копирование в Яндекс.Диск ===
echo "Копирование на удалённый диск..." | tee -a "$LOG_FILE"

rclone copy "$DUMP_DIR/$FILENAME" "$REMOTE" 2>&1 | tee -a "$LOG_FILE"

if [ $? -ne 0 ]; then
    echo "Ошибка копирования в облако!" | tee -a "$LOG_FILE"
    write_metrics_failure
    exit 1
fi

# === Удаление старых бэкапов ===
echo "Удаление старых бэкапов..." | tee -a "$LOG_FILE"

ls -1tr "$DUMP_DIR"/*.dump 2>/dev/null | head -n -7 | xargs -r rm -f

# === УСПЕШНОЕ ЗАВЕРШЕНИЕ ===
echo "Бэкап завершён: $FILENAME" | tee -a "$LOG_FILE"
echo "Время завершения: $(date)" | tee -a "$LOG_FILE"

write_metrics_success