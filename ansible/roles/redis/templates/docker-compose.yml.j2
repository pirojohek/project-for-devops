
services:
  # === Мастера ===
  redis-master-1:
    image: redis:7
    container_name: redis-master-1
    command: ["redis-server", "/usr/local/etc/redis/redis.conf", "--cluster-enabled", "yes", "--appendonly", "yes"]
    ports:
      - "7001:6379"
    volumes:
      - ./redis/node-1/data:/data
      - ./redis/node-1/redis.conf:/usr/local/etc/redis/redis.conf

  redis-master-2:
    image: redis:7
    container_name: redis-master-2
    command: ["redis-server", "/usr/local/etc/redis/redis.conf", "--cluster-enabled", "yes", "--appendonly", "yes"]
    ports:
      - "7002:6379"
    volumes:
      - ./redis/node-2/data:/data
      - ./redis/node-2/redis.conf:/usr/local/etc/redis/redis.conf

  redis-master-3:
    image: redis:7
    container_name: redis-master-3
    command: ["redis-server", "/usr/local/etc/redis/redis.conf", "--cluster-enabled", "yes", "--appendonly", "yes"]
    ports:
      - "7003:6379"
    volumes:
      - ./redis/node-3/data:/data
      - ./redis/node-3/redis.conf:/usr/local/etc/redis/redis.conf

  # === Реплики ===
  redis-replica-1:
    image: redis:7
    container_name: redis-replica-1
    command: ["redis-server", "/usr/local/etc/redis/redis.conf", "--cluster-enabled", "yes", "--appendonly", "yes"]
    ports:
      - "7011:6379"
    volumes:
      - ./redis/node-4/data:/data
      - ./redis/node-4/redis.conf:/usr/local/etc/redis/redis.conf

  redis-replica-2:
    image: redis:7
    container_name: redis-replica-2
    command: ["redis-server", "/usr/local/etc/redis/redis.conf", "--cluster-enabled", "yes", "--appendonly", "yes"]
    ports:
      - "7012:6379"
    volumes:
      - ./redis/node-5/data:/data
      - ./redis/node-5/redis.conf:/usr/local/etc/redis/redis.conf

  redis-replica-3:
    image: redis:7
    container_name: redis-replica-3
    command: ["redis-server", "/usr/local/etc/redis/redis.conf", "--cluster-enabled", "yes", "--appendonly", "yes"]
    ports:
      - "7013:6379"
    volumes:
      - ./redis/node-6/data:/data
      - ./redis/node-6/redis.conf:/usr/local/etc/redis/redis.conf

  # === Redis Exporter для Prometheus ===
  redis-exporter:
    image: oliver006/redis_exporter:latest
    container_name: redis-exporter
    environment:
      - REDIS_ADDR=redis-master-1:6379
      - REDIS_PASSWORD=
    ports:
      - "9121:9121"
    depends_on:
      - redis-master-1
      - redis-master-2
      - redis-master-3